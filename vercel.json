{
    "version": 2,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        { "src": "/cri", "dest": "/api/cri.php" },
        { "src": "/live", "dest": "/api/live.php" },
        { "src": "/xml", "dest": "/api/xml.php" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
