{
    "version": 2,
    "cleanUrls": true,
    "functions": {
        "*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        { "src": "/cri", "dest": "/cri.php" },
        { "src": "/live", "dest": "/live.php" },
        { "src": "/xml", "dest": "/xml.php" },
        { "src": "/(.*\\.txt)", "dest": "/$1" }
    ]
}
